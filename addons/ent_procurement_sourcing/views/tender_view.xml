<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tender_form" model="ir.ui.view">
        <field name="name">ent.tender.form</field>
        <field name="model">ent.tender</field>
        <field name="arch" type="xml">
            <form string="Tender Workspace">
                <header>
                    <button name="action_publish" string="Publish &amp; Invite" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start_tech_eval" string="Close Bidding &amp; Evaluate Tech" type="object" class="oe_highlight" invisible="state != 'published'"/>
                    <button name="action_open_commercial_envelope" string="Unlock Commercial Envelopes" type="object" class="oe_highlight" invisible="state != 'tech_eval'" confirm="Are you sure? This will break the commercial seal for all technically qualified vendors."/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,tech_eval,comm_eval,awarded"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_pos" type="object" class="oe_stat_button" icon="fa-credit-card" invisible="po_count == 0">
                            <field name="po_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="title"/>
                            <field name="ro_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="category_id" readonly="1" force_save="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Requested Items">
                            <field name="line_ids">
                                <tree editable="bottom" create="false">
                                    <field name="name" width="30%" readonly="1" force_save="1"/>
                                    
                                    <field name="product_id" width="30%" required="1" 
                                           context="{
                                               'default_detailed_type': 'consu', 
                                               'default_purchase_ok': True, 
                                               'default_sale_ok': False, 
                                               'default_categ_id': parent.category_id
                                           }"/>
                                           
                                    <field name="quantity" width="15%"/>
                                    <field name="uom_id" width="15%"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Vendor Invitations">
                            <div class="alert alert-info mt-2" role="alert" invisible="state != 'draft'">
                                <i class="fa fa-info-circle"/> Select the vendors to invite. This list will lock permanently once the Tender is Published.
                            </div>
                            <field name="vendor_ids" readonly="state != 'draft'" options="{'no_create': True}">
                                <tree string="Invited Vendors">
                                    <field name="name"/>
                                    <field name="email" optional="show"/>
                                    <field name="phone" optional="show"/>
                                    <field name="city" optional="show"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Vendor Submissions (Two-Envelope)">
                            <field name="bid_ids">
                                <tree decoration-success="tech_status == 'passed'" decoration-danger="tech_status == 'failed'" decoration-muted="tech_status == 'pending'">
                                    <field name="vendor_id" domain="[('id', 'in', parent.vendor_ids)]"/>
                                    
                                    <field name="commercial_price" invisible="parent.state not in ['comm_eval', 'awarded']" readonly="tech_status != 'passed'"/>
                                    <field name="currency_id" invisible="1"/>
                                    
                                    <button name="action_award_bid" type="object" string="Award Winner" class="btn-success" invisible="parent.state != 'comm_eval' or tech_status != 'passed'" confirm="Are you sure you want to award this vendor and generate the Purchase Order?"/>
                                    <field name="po_id" invisible="not po_id"/>
                                </tree>
                                
                                <form string="Bid Submission">
                                    <sheet>
                                        <group>
                                            <field name="vendor_id" domain="[('id', 'in', parent.vendor_ids)]"/>
                                        </group>
                                        
                                        <group string="Envelope 1: Technical">
                                            <group>
                                                <field name="tech_proposal_filename" invisible="1"/>
                                                <field name="tech_proposal" filename="tech_proposal_filename" widget="binary" readonly="parent.state != 'published'"/>
                                            </group>
                                            <group>
                                                <field name="tech_status" readonly="parent.state != 'tech_eval'"/>
                                            </group>
                                        </group>
                                        
                                        <group string="Envelope 2: Commercial (Sealed)" invisible="parent.state not in ['comm_eval', 'awarded']">
                                            <field name="bid_line_ids" readonly="tech_status != 'passed'">
                                                <tree editable="bottom" create="false" delete="false">
                                                    <field name="name"/>
                                                    <field name="quantity"/>
                                                    <field name="uom_id"/>
                                                    <field name="price_unit"/>
                                                    <field name="subtotal"/>
                                                    <field name="currency_id" invisible="1"/>
                                                </tree>
                                            </field>
                                            
                                            <group class="oe_subtotal_footer oe_right">
                                                <field name="commercial_price" class="oe_subtotal_footer_separator"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tender" model="ir.actions.act_window">
        <field name="name">Tenders Workspace</field>
        <field name="res_model">ent.tender</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_ent_sourcing" name="Sourcing" parent="ent_procurement_demand.menu_ent_procurement_root" sequence="20"/>
    <menuitem id="menu_tender" name="Tenders Workspace" parent="menu_ent_sourcing" action="action_tender" sequence="10"/>
</odoo>