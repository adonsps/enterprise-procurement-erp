<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_request_order_form" model="ir.ui.view">
        <field name="name">ent.request.order.form</field>
        <field name="model">ent.request.order</field>
        <field name="arch" type="xml">
            <form string="Request Order">
                <header>
                    <button name="action_submit" string="Submit to Matrix" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g., RO-2026-001"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="request_title" placeholder="e.g., IT Hardware Refresh"/>
                            
                            <label for="category_id"/>
                            <div class="o_row">
                                <field name="category_id" 
                                       context="{'short_category_name': True}" 
                                       options="{'no_create': True, 'no_open': True}"/>
                                <button name="action_suggest_category_ai" type="object" string="Auto-Detect via AI" class="btn-link" icon="fa-magic"/>
                            </div>
                            
                            <field name="pic_id"/>
                        </group>
                        <group>
                            <field name="department"/>
                            <field name="requestor_id"/>
                            <field name="estimated_budget" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Line Items">
                            <field name="line_ids" widget="section_and_note_one2many">
                                <tree editable="bottom">
                                    <field name="name" width="40%"/>
                                    <field name="quantity" width="10%"/>
                                    <field name="uom_id" width="10%" options="{'no_create': True}"/>
                                    <field name="estimated_price" width="20%"/>
                                    <field name="subtotal" width="20%"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Justification &amp; Specs">
                            <group>
                                <field name="tor_filename" invisible="1"/>
                                <field name="tor_attachment" filename="tor_filename" widget="binary"/>
                            </group>
                            <field name="description" placeholder="Provide detailed justification for the AI to analyze..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_request_order_tree" model="ir.ui.view">
        <field name="name">ent.request.order.tree</field>
        <field name="model">ent.request.order</field>
        <field name="arch" type="xml">
            <tree string="Request Orders">
                <field name="name"/>
                <field name="request_title"/>
                <field name="requestor_id"/>
                <field name="estimated_budget"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-info="state == 'submitted'"/>
            </tree>
        </field>
    </record>

    <record id="action_request_order" model="ir.actions.act_window">
        <field name="name">Request Orders</field>
        <field name="res_model">ent.request.order</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_ent_procurement_root" name="E-Procurement" sequence="10"/>
    <menuitem id="menu_ent_demand" name="Demand &amp; Planning" parent="menu_ent_procurement_root" sequence="10"/>
    <menuitem id="menu_request_order" name="Request Orders" parent="menu_ent_demand" action="action_request_order" sequence="10"/>

    <menuitem id="menu_ent_config" name="Configuration" parent="menu_ent_procurement_root" sequence="100"/>
    <menuitem id="menu_ent_item_taxonomy" name="Item Taxonomy (Categories)" parent="menu_ent_config" action="product.product_category_action_form" sequence="10"/>
</odoo>