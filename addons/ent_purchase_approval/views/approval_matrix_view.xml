<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_matrix_tree" model="ir.ui.view">
        <field name="name">ent.approval.matrix.tree</field>
        <field name="model">ent.approval.matrix</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="approver_id"/>
                <field name="limit_amount"/>
                <field name="currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="action_approval_matrix" model="ir.actions.act_window">
        <field name="name">PO Approval Matrix</field>
        <field name="res_model">ent.approval.matrix</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_ent_approval_matrix" name="PO Approval Matrix" parent="ent_procurement_demand.menu_ent_config" action="action_approval_matrix" sequence="30"/>
</odoo>