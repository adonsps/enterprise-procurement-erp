<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_approval" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="action_approve_po_custom" string="Approve Purchase" type="object" class="btn-success" invisible="state != 'to approve'"/>
                <button name="action_reject_po_custom" string="Reject" type="object" class="btn-danger" invisible="state != 'to approve'"/>
            </xpath>

            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning text-center o_form_header" role="alert" invisible="state != 'to approve'">
                    <strong>Pending Approval From: </strong>
                    <field name="current_approver_id" readonly="1"/>
                </div>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Approval Matrix Workflow" name="approval_matrix">
                    <field name="approval_line_ids" readonly="1">
                        <tree decoration-success="status == 'approved'" decoration-danger="status == 'rejected'" decoration-muted="status == 'pending'">
                            <field name="matrix_id"/>
                            <field name="approver_id"/>
                            <field name="status" widget="badge" 
                                   decoration-success="status == 'approved'" 
                                   decoration-danger="status == 'rejected'" 
                                   decoration-warning="status == 'pending'"/>
                            <field name="date_approved"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>
</odoo>